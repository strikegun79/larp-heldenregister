includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    paths:
        - app/

    level: 5

    # Laravel-spezifische Ignores
    ignoreErrors:

    # Dateien, die PHPStan nicht analysiert (optional: Datei muss nicht existieren)
    excludePaths:
        analyseAndScan:
            - app/Console/Commands/MigrateLegacyCommand.php (?)

    # Parallele Analyse für schnellere Läufe
    parallel:
        maximumNumberOfProcesses: 4
