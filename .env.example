# ============================================================
# Heldenregister – Umgebungskonfiguration
# Kopiere diese Datei nach .env und fülle alle Werte aus.
# Geheime Werte (Passwörter, Tokens) NIEMALS ins Repository!
# ============================================================

APP_NAME="Heldenregister"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://heldenregister.example.de

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
# Produktion: 'warning' oder 'error'; Entwicklung: 'debug'
LOG_LEVEL=warning
# Anzahl Tage, die rotierende Log-Dateien aufbewahrt werden (daily-Channel)
LOG_DAILY_DAYS=30

# ------------------------------------------------------------
# Datenbank (Haupt-DB)
# ------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=heldenregister
DB_USERNAME=heldenregister
DB_PASSWORD=

# ------------------------------------------------------------
# Legacy-Datenbank (nur für ETL-Migration; danach entfernen)
# Leer lassen, wenn keine Legacy-Migration läuft.
# ------------------------------------------------------------
LEGACY_DB_HOST=127.0.0.1
LEGACY_DB_PORT=3306
LEGACY_DB_DATABASE=larp_buerokrat
LEGACY_DB_USERNAME=
LEGACY_DB_PASSWORD=

# ------------------------------------------------------------
# Matrix-Homeserver (matrix-corporal-Integration)
# ------------------------------------------------------------
MATRIX_DOMAIN=waldritter-giessen.de
MATRIX_CORPORAL_TOKEN=

# ------------------------------------------------------------
# Cache / Session / Queue
# Produktion: QUEUE_CONNECTION=database + Queue-Worker-Service
# einrichten (siehe docs/deployment.md – Abschnitt Queue-Worker).
# ------------------------------------------------------------
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ------------------------------------------------------------
# Backup (INFRA-06, spatie/laravel-backup)
# BACKUP_DISK_PATH: Zielverzeichnis außerhalb des Web-Roots empfohlen.
# BACKUP_MAIL_TO: Empfänger für Fehler-Benachrichtigungen.
# BACKUP_ARCHIVE_PASSWORD: optional; ZIP-Verschlüsselung.
# ------------------------------------------------------------
BACKUP_DISK_PATH=/var/backups/heldenregister
BACKUP_MAIL_TO=admin@example.de
BACKUP_ARCHIVE_PASSWORD=

# ------------------------------------------------------------
# E-Mail
# ------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="heldenregister@example.de"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------
# Vite (Frontend-Build)
# ------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
