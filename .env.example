# ============================================================
# Heldenregister – Umgebungskonfiguration
# Kopiere diese Datei nach .env und fülle alle Werte aus.
# Geheime Werte (Passwörter, Tokens) NIEMALS ins Repository!
# ============================================================

APP_NAME="Heldenregister"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://heldenregister.example.de

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
# Produktion: 'warning' oder 'error'; Entwicklung: 'debug'
LOG_LEVEL=warning

# ------------------------------------------------------------
# Datenbank (Haupt-DB)
# ------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=heldenregister
DB_USERNAME=heldenregister
DB_PASSWORD=

# ------------------------------------------------------------
# Legacy-Datenbank (nur für ETL-Migration; danach entfernen)
# Leer lassen, wenn keine Legacy-Migration läuft.
# ------------------------------------------------------------
LEGACY_DB_HOST=127.0.0.1
LEGACY_DB_PORT=3306
LEGACY_DB_DATABASE=larp_buerokrat
LEGACY_DB_USERNAME=
LEGACY_DB_PASSWORD=

# ------------------------------------------------------------
# Matrix-Homeserver (matrix-corporal-Integration)
# ------------------------------------------------------------
MATRIX_DOMAIN=waldritter-giessen.de
MATRIX_CORPORAL_TOKEN=

# ------------------------------------------------------------
# Cache / Session / Queue
# Produktion: cache + session auf 'database' oder 'redis';
# Queue auf 'database' (mit Worker-Service, siehe INFRA-04).
# ------------------------------------------------------------
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ------------------------------------------------------------
# E-Mail
# ------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="heldenregister@example.de"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------
# Vite (Frontend-Build)
# ------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
