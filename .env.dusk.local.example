# Vorlage für Dusk-Browser-Tests. Kopieren nach .env.dusk.local
# und Zugangsdaten anpassen, dann:
#   php artisan serve --env=dusk.local --port=8000 &
#   php artisan dusk

APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=larp_heldenregister_laravel_test
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=array
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
